{
  "name": "alwan",
  "version": "1.0.0",
  "description": "Alwan Microfinance Platform - Monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "alwan-web",
    "alwan-mobile"
  ],
  "scripts": {
    "web": "cd alwan-web && npm run dev -- -p 3000",
    "mobile": "cd alwan-mobile && npm start",
    "mobile:web": "cd alwan-mobile && npm run web -- --port 19006",
    "dev:all": "concurrently \"npm run web\" \"npm run mobile:web\" --names \"web,mobile\" --prefix-colors \"cyan,magenta\"",
    "dev:web": "cd alwan-web && npm run dev",
    "dev:mobile": "cd alwan-mobile && npm start",
    "build:web": "cd alwan-web && npm run build",
    "build:mobile": "cd alwan-mobile && npm run build",
    "build:shared": "cd packages/shared && npm run build",
    "build:all": "npm run build:shared && npm run build:web && npm run build:mobile",
    "clean": "rm -rf node_modules alwan-web/node_modules alwan-mobile/node_modules packages/*/node_modules packages/*/dist",
    "setup": "npm install && cd alwan-web && npm install && cd ../alwan-mobile && npm install && cd ../packages/shared && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ardfaiyaz/alwan.git"
  },
  "keywords": [
    "microfinance",
    "kmbi",
    "alwan",
    "fintech",
    "philippines"
  ],
  "author": "",
  "license": "ISC"
}
